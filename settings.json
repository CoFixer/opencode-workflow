{
    "framework": "opencode",
    "version": "1.0",
    "permissions": {
        "allow": [
            "Edit:*",
            "Write:*",
            "MultiEdit:*",
            "Bash:*"
        ],
        "defaultMode": "acceptEdits"
    },
    "skills": {
        "enabled": true,
        "rulesFile": "./skill-rules.json",
        "autoActivate": true
    },
    "agents": {
        "enabled": true,
        "registryFile": "./agents/agent-manifest.json",
        "defaultAgent": "project-coordinator"
    },
    "prompts": {
        "directory": "./prompts",
        "defaultPrompt": "feature-spec"
    },
    "guides": {
        "directories": [
            "./guides",
            "./backend/guides",
            "./frontend/guides",
            "./mobile/guides",
            "./base/guides"
        ]
    },
    "docs": {
        "directories": [
            "./base/docs",
            "./base/docs/checklists",
            "./base/docs/guides"
        ]
    },
    "hooks": {
        "UserPromptSubmit": [
            {
                "hooks": [
                    {
                        "type": "command",
                        "command": "node $PROJECT_DIR/.opencode/hooks/skill-activation-prompt.js"
                    }
                ]
            }
        ],
        "Stop": [
            {
                "hooks": [
                    {
                        "type": "command",
                        "command": "node $PROJECT_DIR/.opencode/hooks/auto-reflect.js"
                    },
                    {
                        "type": "command",
                        "command": "node $PROJECT_DIR/.opencode/hooks/status-auto-updater.js"
                    }
                ]
            }
        ]
    },
    "project": {
        "sharedHub": ".project/",
        "docsPath": ".project/docs/",
        "memoryPath": ".project/memory/",
        "statusPath": ".project/status/",
        "prdPath": ".project/prd/"
    },
    "preferences": {
        "codeStyle": "minimal-changes",
        "testBeforeCommit": true,
        "followExistingPatterns": true,
        "documentationOnChange": true
    }
}

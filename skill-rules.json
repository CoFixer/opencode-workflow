{
  "version": "1.0",
  "rules": [
    {
      "name": "commit",
      "trigger": "/skill:commit",
      "description": "Git commit & PR workflow",
      "keywords": ["commit", "ship changes", "git commit", "create pr", "merge pr"]
    },
    {
      "name": "create-dev-pr",
      "trigger": "/skill:create-dev-pr",
      "description": "Create a PR to the dev branch with validation",
      "keywords": ["create pr", "dev pr", "pull request", "pr to dev"]
    },
    {
      "name": "find-gaps",
      "trigger": "/skill:find-gaps",
      "description": "Find design-to-code gaps and compliance issues",
      "keywords": ["find gaps", "gap analysis", "check gaps", "missing features", "what's left"]
    },
    {
      "name": "fix-gaps",
      "trigger": "/skill:fix-gaps",
      "description": "Fix gaps found by gap analysis",
      "keywords": ["fix gaps", "fix issues", "resolve gaps", "fix problems"]
    },
    {
      "name": "generate-docs",
      "trigger": "/skill:generate-docs",
      "description": "Generate API, database, and knowledge docs",
      "keywords": ["generate docs", "update docs", "documentation", "api docs", "database docs"]
    },
    {
      "name": "generate-ouroboros",
      "trigger": "/skill:generate-ouroboros",
      "description": "Validate PRD features through Socratic interview",
      "keywords": ["ouroboros", "validate prd", "socratic interview", "spec validation"]
    },
    {
      "name": "review-tickets",
      "trigger": "/skill:review-tickets",
      "description": "Review and fix Notion tickets",
      "keywords": ["review tickets", "notion tickets", "fix ticket", "ticket review"]
    },
    {
      "name": "run-fullstack",
      "trigger": "/skill:run-fullstack",
      "description": "Run the full-stack development pipeline",
      "keywords": ["run fullstack", "fullstack pipeline", "start development", "build project"]
    },
    {
      "name": "reflect",
      "trigger": "/skill:reflect",
      "description": "Analyze conversation for learnings",
      "keywords": ["reflect", "learnings", "session analysis", "capture learnings"]
    },
    {
      "name": "generate-prd",
      "trigger": "/skill:generate-prd",
      "description": "Generate PRD from client input",
      "keywords": ["generate prd", "product requirements", "write prd", "create prd"]
    },
    {
      "name": "generate-ppt",
      "trigger": "/skill:generate-ppt",
      "description": "Generate HTML presentations",
      "keywords": ["generate ppt", "presentation", "slides", "reveal.js"]
    },
    {
      "name": "generate-proposal",
      "trigger": "/skill:generate-proposal",
      "description": "Generate client proposals",
      "keywords": ["generate proposal", "client proposal", "proposal deck"]
    },
    {
      "name": "generate-invoice",
      "trigger": "/skill:generate-invoice",
      "description": "Generate invoices and quotations",
      "keywords": ["generate invoice", "quotation", "estimate", "pdf invoice"]
    },
    {
      "name": "run-playwright",
      "trigger": "/skill:run-playwright",
      "description": "Run Playwright E2E tests",
      "keywords": ["run playwright", "e2e tests", "playwright tests", "browser automation"]
    }
  ]
}
